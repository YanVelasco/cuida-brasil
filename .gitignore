# ==========================================
# Cuidar+ Brasil - Global Git Ignore File
# ==========================================

# ------------------------------------------
# Operating System & IDE Files
# ------------------------------------------
# Windows thumbnail database / desktop config
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# macOS files
.DS_Store
.AppleDouble
.LSOverride
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent

# JetBrains / IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# Visual Studio Code
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
.history/
*.code-workspace

# ------------------------------------------
# Node.js & Frontend (Vite, React, CSS Modules)
# ------------------------------------------
# Dependency directories
node_modules/
jspm_packages/

# Production / Build artifacts
dist/
dist-ssr/
build/
out/
.svelte-kit/
.next/
.nuxt/

# Debug and performance logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Formatting & Linting cache
.eslintcache
.prettiercache
.stylelintcache

# Local environment configs (Contains sensitive credentials!)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*.local
!.env.example

# ------------------------------------------
# Backend / Java / Maven
# ------------------------------------------
# Maven build target directory
target/
**/target/

# Class files & Compiled outputs
*.class
*.jar
*.war
*.ear
*.nar

# Maven wrapper cache (keep scripts, ignore download jar if preferred)
.mvn/wrapper/
!.mvn/wrapper/maven-wrapper.properties

# Crash dumps
hs_err_pid*
replay_pid*

# ------------------------------------------
# Database & Cache files
# ------------------------------------------
*.db
*.sqlite
*.sqlite3
.cache/

# ==========================================
